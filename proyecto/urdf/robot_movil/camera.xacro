<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
<gazebo reference="$(arg namespace)/base_camera">
     <sensor name="camara" type="camera">
         <topic>/$(arg namespace)/camara</topic>
         <pose> 0 0 0 0 0 0</pose>
         <always_on>1</always_on>
         <update_rate>25</update_rate>
         <camera name="camera_front">
           <horizontal_fov>1.658</horizontal_fov>
           <lens>
             <intrinsics>
               <!-- fx = fy = width / ( 2 * tan (hfov / 2 ) ) -->
               <fx>494.85</fx>
               <fy>494.85</fy>
               <!-- cx = ( width - 1 ) / 2 -->
               <cx>539.5</cx>
               <!-- cy = ( height - 1 ) / 2 -->
               <cy>539.5</cy>
               <s>0</s>
             </intrinsics>
           </lens>
           <distortion>
             <k1>0.0</k1>
             <k2>0.0</k2>
             <k3>0.0</k3>
             <p1>0.0</p1>
             <p2>0.0</p2>
             <center>0.5 0.5</center>
           </distortion>
           <image>
             <width>1080</width>
             <height>720</height>
             <format>R8G8B8</format>
           </image>
           <clip>
             <near>0.01</near>
             <far>300</far>
           </clip>
           <noise>
             <type>gaussian</type>
             <mean>0</mean>
             <stddev>0.007</stddev>
           </noise>
         </camera>
       </sensor>
</gazebo>
</robot>
